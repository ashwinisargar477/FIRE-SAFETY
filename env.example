# Copy to `.env` or `.env.local` and fill in real values.
# After changes, restart `npm run dev`.

# --- Email (required for real “empty cylinder” notifications) ---
# Gmail: use an App Password, not your normal password.
# (Google Account → Security → 2-Step Verification → App passwords)
# Microsoft 365 (e.g. reports@nuvoco.com): often SMTP_HOST=smtp.office365.com, SMTP_PORT=587, SMTP_USER=full mailbox address.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.address@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Nuvoco Fire Safety <your.address@gmail.com>"

# Optional: extra recipients (comma-separated)
PLANT_ISSUE_FALLBACK_EMAIL=

# Optional: primary inbox for issue mail (comma-separated). If unset, ashwinisargar18@gmail.com is used as fallback.
ISSUE_NOTIFY_EMAIL=

# Inspection-pending digest (extinguishers with no inspection in 3 months). Comma-separated admin inboxes.
INSPECTION_PENDING_ADMIN_EMAIL=
# Minimum hours between digest emails (default 24). Put real SMTP credentials in .env.local only — do not commit secrets.
INSPECTION_PENDING_DIGEST_HOURS=24
